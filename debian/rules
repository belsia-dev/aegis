#!/usr/bin/make -f

%:
	dh $@ --with python3

override_dh_auto_build:

override_dh_auto_test:

override_dh_auto_install:
	install -d $(CURDIR)/debian/aegis/usr/lib/aegis
	cp -a api core detection integrations monitors response scripts $(CURDIR)/debian/aegis/usr/lib/aegis/
	install -m 0644 main.py $(CURDIR)/debian/aegis/usr/lib/aegis/main.py
	install -m 0644 __init__.py $(CURDIR)/debian/aegis/usr/lib/aegis/__init__.py
	install -m 0644 requirements.txt $(CURDIR)/debian/aegis/usr/lib/aegis/requirements.txt
	find $(CURDIR)/debian/aegis/usr/lib/aegis -name __pycache__ -type d -prune -exec rm -rf {} +
	find $(CURDIR)/debian/aegis/usr/lib/aegis -name '*.pyc' -delete
	find $(CURDIR)/debian/aegis/usr/lib/aegis -name '*.pyo' -delete
	find $(CURDIR)/debian/aegis/usr/lib/aegis -name '.DS_Store' -delete
	install -d $(CURDIR)/debian/aegis/etc/aegis
	install -m 0644 config.example.yaml $(CURDIR)/debian/aegis/etc/aegis/config.yaml
	install -d $(CURDIR)/debian/aegis/usr/bin
	install -m 0755 debian/aegis-wrapper $(CURDIR)/debian/aegis/usr/bin/aegis

override_dh_installsystemd:
	dh_installsystemd --no-enable --no-start
